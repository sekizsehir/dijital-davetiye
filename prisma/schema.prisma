generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Ayar {
  anahtar String @id
  deger   String
}

model Davetli {
  id              Int       @id @default(autoincrement())
  kod             String    @unique
  ad              String
  soyad           String
  il              String?
  ilce            String?
  email           String?
  telefon         String?
  katilimVar      Boolean   @default(false)
  katilimTarihi   DateTime?
  olusturmaTarihi DateTime  @default(now())
}
